# Supabase transaction pooler — what the app queries at runtime (see README
# for why this needs to be split from DIRECT_URL):
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Supabase session pooler — used only for `prisma migrate`:
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres"
# Local Postgres via docker-compose, alternative to Supabase (same value for both):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/micromesomacro"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/micromesomacro"
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
STEAM_API_KEY=""
STEAM_REALM="http://localhost:3000"
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""
