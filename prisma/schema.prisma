generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Transaction pooler (PgBouncer) — what the app actually queries through.
  // Built for many short-lived serverless connections; the session pooler
  // (DIRECT_URL) only supports 15 concurrent clients, which a handful of
  // concurrent Vercel function instances can exhaust on their own.
  url       = env("DATABASE_URL")
  // Session pooler — only used for `prisma migrate deploy`/`dev`, which
  // need session-level features the transaction pooler doesn't support.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  steamId       String?   @unique
  // Identifies a guest "shadow" account tied to a browser cookie, so
  // anonymous visitors can submit ratings without connecting Steam.
  anonId        String?   @unique
  accounts      Account[]
  sessions      Session[]
  ratings       Rating[]
  steamLibrary  SteamLibraryLink?
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id          String      @id @default(cuid())
  igdbId      Int?        @unique
  steamAppId  Int?        @unique
  slug        String      @unique
  title       String
  description String?
  headerImage String?
  releaseDate DateTime?
  metadata    Json?
  ratings     Rating[]
  ownedBy     OwnedGame[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  micro     Int
  meso      Int
  macro     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
}

model SteamLibraryLink {
  id         String      @id @default(cuid())
  userId     String      @unique
  steamId    String      @unique
  lastSyncAt DateTime?
  syncStatus String      @default("idle")
  syncError  String?
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownedGames OwnedGame[]
}

model OwnedGame {
  id           String           @id @default(cuid())
  libraryId    String
  gameId       String?
  steamAppId   Int
  playtimeMins Int?
  library      SteamLibraryLink @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  game         Game?            @relation(fields: [gameId], references: [id])

  @@unique([libraryId, steamAppId])
}

// Tracks outcomes of batched IGDB lookups (external_games resolve + games
// fetch) so we can see the real-world failure rate and tell whether the
// batching approach needs to be revisited (e.g. IGDB rejecting large
// `where field = (...)` lists) rather than guessing from anecdotal reports.
model IgdbBatchLog {
  id            String   @id @default(cuid())
  operation     String
  requestedIds  Int
  resolvedCount Int
  ok            Boolean
  error         String?
  createdAt     DateTime @default(now())

  @@index([operation, ok])
}
